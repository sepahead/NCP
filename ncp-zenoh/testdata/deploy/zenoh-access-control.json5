// NCP secure Zenoh router template — mTLS + per-plane ACL.
//
// The action/command plane is world-writable on an open realm (see SECURITY.md):
// anyone who can reach `{realm}/session/*/command` can drive an actuator. This
// config closes that with a default-DENY ACL in which only the *authenticated*
// `commander` subject may PUBLISH commands and issue lifecycle queries; the body
// publishes sensors/observations, reads commands, and serves lifecycle replies;
// observers may only READ. The planes get distinct per-subject permissions, so a
// perception-only client can never command.
// This protects router key access only. It cannot bind payload IdentityClaim to the
// verified remote principal; the current ncp-zenoh adapter lacks that callback data
// and fails closed for production-secure startup.
//
// TEMPLATE — `commander`/`body`/`observer` are ROLES, not project names. Replace
// the certificate paths/CNs, and render a non-default realm with:
//   python3 scripts/render_acl_template.py --realm engram/ncp \
//     --session-id acl-verify --output router.json5
// CN matching is exact (never globbed). Missing placeholder certificates make
// startup fail; this file is intentionally not an anonymously usable router.
// NCP_SESSION_ID is a literal rendering sentinel, not a wildcard. This minimal
// template grants only aggregate command and sensor routes for one exact session.
// Deployments using named channels or more sessions must generate and review more
// concrete PUT routes. Never replace the sentinel with `*`, or grant command PUT
// on `command/*`/`command/**`: Zenoh permits wildcard key-expression publishers,
// which violates NCP's wildcard-action-publisher prohibition.
// This minimal profile deliberately enrolls no operator transport subject. A
// deployment that needs the normative operator action role must add a distinct
// certificate subject, exact action-plane rules, and matching authority-manifest
// grants. Do not widen commander rules to approximate one. Wire 1.0 has no stable
// ESTOP-reset RPC.
{
  mode: "router",
  connect: { endpoints: [] },
  listen: {
    endpoints: ["tls/0.0.0.0:7447"],
    exit_on_failure: true,
  },
  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false },
  },
  transport: {
    link: {
      tls: {
        root_ca_certificate: "deploy/certs/ca.pem",
        listen_private_key: "deploy/certs/router-key.pem",
        listen_certificate: "deploy/certs/router.pem",
        enable_mtls: true,
        close_link_on_expiration: true,
      },
    },
  },

  access_control: {
    enabled: true,
    // Fail closed: anything not explicitly allowed is denied.
    default_permission: "deny",

    // Flow is relative to each authenticated client link. Ingress is client →
    // router; egress is router → client. Subscriber/queryable declarations and
    // delivered PUT/query/reply messages therefore require different directions.
    rules: [
      // ── Commander (controller/brain): exact-session aggregate command
      // publisher, body-data subscriber, and lifecycle querier only.
      {
        id: "commander-command-ingress",
        messages: ["put"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: ["ncp/session/NCP_SESSION_ID/command"],
      },
      {
        id: "commander-command-matching-egress",
        messages: ["declare_subscriber"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/command",
          "ncp/session/NCP_SESSION_ID/**",
          "ncp/session/**",
        ],
      },
      {
        id: "commander-body-subscription-ingress",
        messages: ["declare_subscriber"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/sensor/**",
          "ncp/session/NCP_SESSION_ID/observation",
        ],
      },
      {
        id: "commander-body-data-egress",
        messages: ["put"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/sensor",
          "ncp/session/NCP_SESSION_ID/observation",
        ],
      },
      {
        id: "commander-rpc-query-ingress",
        messages: ["query"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: [
          "ncp/rpc/open_session",
          "ncp/rpc/step_request",
          "ncp/rpc/run_request",
          "ncp/rpc/close_session",
        ],
      },
      {
        id: "commander-rpc-discovery-egress",
        messages: ["declare_queryable"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: ["ncp/rpc/*"],
      },
      {
        id: "commander-rpc-reply-egress",
        messages: ["reply"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/rpc/open_session",
          "ncp/rpc/step_request",
          "ncp/rpc/run_request",
          "ncp/rpc/close_session",
        ],
      },

      // ── Body (simulator/plant): exact-session aggregate data publisher,
      // command subscriber, and lifecycle queryable/replier only.
      {
        id: "body-data-ingress",
        messages: ["put"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/sensor",
          "ncp/session/NCP_SESSION_ID/observation",
        ],
      },
      {
        id: "body-data-matching-egress",
        messages: ["declare_subscriber"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/sensor/**",
          "ncp/session/NCP_SESSION_ID/observation",
          "ncp/session/NCP_SESSION_ID/**",
          "ncp/session/**",
        ],
      },
      {
        id: "body-command-subscription-ingress",
        messages: ["declare_subscriber"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: ["ncp/session/NCP_SESSION_ID/command"],
      },
      {
        id: "body-command-data-egress",
        messages: ["put"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: ["ncp/session/NCP_SESSION_ID/command"],
      },
      {
        id: "body-rpc-queryable-ingress",
        messages: ["declare_queryable"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: ["ncp/rpc/*"],
      },
      {
        id: "body-rpc-reply-ingress",
        messages: ["reply"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: [
          "ncp/rpc/open_session",
          "ncp/rpc/step_request",
          "ncp/rpc/run_request",
          "ncp/rpc/close_session",
        ],
      },
      {
        id: "body-rpc-query-egress",
        messages: ["query"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/rpc/open_session",
          "ncp/rpc/step_request",
          "ncp/rpc/run_request",
          "ncp/rpc/close_session",
        ],
      },

      // ── Observer (analysis tap): broad declarations are read-only. PUT
      // delivery remains restricted to the three exact routes above.
      {
        id: "observer-subscription-ingress",
        messages: ["declare_subscriber"],
        flows: ["ingress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/**",
          "ncp/session/**",
        ],
      },
      {
        id: "observer-data-egress",
        messages: ["put"],
        flows: ["egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/NCP_SESSION_ID/sensor",
          "ncp/session/NCP_SESSION_ID/command",
          "ncp/session/NCP_SESSION_ID/observation",
        ],
      },
    ],

    // Identity: map PROVEN mTLS client-cert common-names to subjects. Pair this
    // with mutual TLS (see SECURITY.md "Enabling transport authentication") so
    // these common-names are actually proven — an open realm without mTLS makes
    // every subject trivially spoofable and this ACL meaningless.
    //
    // The CNs here are ROLE placeholders — replace them with the actual cert CNs your
    // deployment issues. Zenoh matches `cert_common_names` by EXACT string equality,
    // not glob. List every issued leaf CN explicitly; do NOT use wildcard-looking
    // values such as "body-*" because they match only that literal string.
    subjects: [
      { id: "commander", cert_common_names: ["commander", "commander-service"] },
      { id: "body", cert_common_names: ["body", "body-1"] },
      { id: "observer", cert_common_names: ["observer", "observer-1", "analysis"] },
    ],

    // Bind rules to subjects. THE SAFETY INVARIANT concerns ingress authority:
    // only commander may send command PUT; only body may send sensor or
    // observation PUT and serve RPC replies. Egress PUT rules only
    // permit delivery to an authenticated subscriber; they grant no publish right.
    policies: [
      {
        rules: [
          "commander-command-ingress",
          "commander-command-matching-egress",
          "commander-body-subscription-ingress",
          "commander-body-data-egress",
          "commander-rpc-query-ingress",
          "commander-rpc-discovery-egress",
          "commander-rpc-reply-egress",
        ],
        subjects: ["commander"],
      },
      {
        rules: [
          "body-data-ingress",
          "body-data-matching-egress",
          "body-command-subscription-ingress",
          "body-command-data-egress",
          "body-rpc-queryable-ingress",
          "body-rpc-reply-ingress",
          "body-rpc-query-egress",
        ],
        subjects: ["body"],
      },
      {
        rules: ["observer-subscription-ingress", "observer-data-egress"],
        subjects: ["observer"],
      },
    ],
  },
}
