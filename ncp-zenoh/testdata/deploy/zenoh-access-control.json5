// NCP secure Zenoh router template — mTLS + per-plane ACL.
//
// The action/command plane is world-writable on an open realm (see SECURITY.md):
// anyone who can reach `{realm}/session/*/command` can drive an actuator. This
// config closes that with a default-DENY ACL in which only the *authenticated*
// `commander` subject may PUBLISH commands; the robot publishes only its sensors
// and reads commands; observers may only READ. The three planes get distinct
// per-subject permissions, so a perception-only client can never command.
// This protects router key access only. It cannot bind payload IdentityClaim to the
// verified remote principal; the current ncp-zenoh adapter lacks that callback data
// and fails closed for production-secure startup.
//
// TEMPLATE — `commander`/`robot`/`observer` are ROLES, not project names. Replace
// the certificate paths/CNs, and render a non-default realm with:
//   python3 scripts/render_acl_template.py --realm engram/ncp --output router.json5
// CN matching is exact (never globbed). Missing placeholder certificates make
// startup fail; this file is intentionally not an anonymously usable router.
{
  mode: "router",
  connect: { endpoints: [] },
  listen: {
    endpoints: ["tls/0.0.0.0:7447"],
    exit_on_failure: true,
  },
  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false },
  },
  transport: {
    link: {
      tls: {
        root_ca_certificate: "deploy/certs/ca.pem",
        listen_private_key: "deploy/certs/router-key.pem",
        listen_certificate: "deploy/certs/router.pem",
        enable_mtls: true,
        close_link_on_expiration: true,
      },
    },
  },

  access_control: {
    enabled: true,
    // Fail closed: anything not explicitly allowed is denied.
    default_permission: "deny",

    rules: [
      // ── Commander (the simulation/brain, e.g. an Engram/NEST host): the ONLY
      // subject permitted to PUBLISH on the safety-critical action (command) plane.
      // Also emits neural data on the observation plane, reads sensors to compute,
      // and answers the session-lifecycle RPC queryable.
      {
        id: "commander-publishes-command-observation",
        messages: ["put", "delete"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/*/command/**",
          "ncp/session/*/observation",
        ],
      },
      {
        id: "commander-reads-sensor",
        messages: ["declare_subscriber"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: ["ncp/session/*/sensor/**"],
      },
      {
        id: "commander-rpc",
        messages: ["declare_queryable", "reply", "query"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: ["ncp/rpc/*"],
      },

      // ── Robot / plant (the body): publishes its own sensors and subscribes
      // commands. It can NEVER publish on the command or observation planes — it
      // holds no rule that PUTs there, so default-deny blocks it. NB: the sensor
      // plane is itself a CONTROL INPUT — a spoofed SensorFrame steers the brain
      // and can defeat the geofence (false-data injection) — so sensor-PUT is
      // restricted to `robot` (enforced by scripts/check_acl_template.py),
      // symmetric to command-PUT being restricted to `commander`.
      {
        id: "robot-publishes-sensor",
        messages: ["put", "delete"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: ["ncp/session/*/sensor/**"],
      },
      {
        id: "robot-reads-command",
        messages: ["declare_subscriber"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: ["ncp/session/*/command/**"],
      },

      // ── Observers (analysis taps): READ-ONLY across the data planes. Reading
      // commands supports aligned control analysis; no PUT/DELETE rule is granted.
      {
        id: "observer-reads",
        messages: ["declare_subscriber"],
        flows: ["ingress", "egress"],
        permission: "allow",
        key_exprs: [
          "ncp/session/*/sensor/**",
          "ncp/session/*/command/**",
          "ncp/session/*/observation",
        ],
      },
    ],

    // Identity: map PROVEN mTLS client-cert common-names to subjects. Pair this
    // with mutual TLS (see SECURITY.md "Enabling transport authentication") so
    // these common-names are actually proven — an open realm without mTLS makes
    // every subject trivially spoofable and this ACL meaningless.
    //
    // The CNs here are ROLE placeholders — replace them with the actual cert CNs your
    // deployment issues. Zenoh matches `cert_common_names` by EXACT string equality,
    // not glob. List every issued leaf CN explicitly; do NOT use wildcard-looking
    // values such as "robot-*" because they match only that literal string.
    subjects: [
      { id: "commander", cert_common_names: ["commander", "commander-service"] },
      { id: "robot", cert_common_names: ["robot", "robot-1"] },
      { id: "observer", cert_common_names: ["observer", "observer-1", "analysis"] },
    ],

    // Bind rules to subjects. THE SAFETY INVARIANT: only `commander` holds a rule
    // that PUTs on `…/command/**`; neither `robot` nor `observer` ever can.
    policies: [
      {
        rules: [
          "commander-publishes-command-observation",
          "commander-reads-sensor",
          "commander-rpc",
        ],
        subjects: ["commander"],
      },
      {
        rules: ["robot-publishes-sensor", "robot-reads-command"],
        subjects: ["robot"],
      },
      { rules: ["observer-reads"], subjects: ["observer"] },
    ],
  },
}
