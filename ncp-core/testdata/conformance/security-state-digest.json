        "bind": {"kind": "tcp", "host": "::ffff:127.0.0.1", "port": 7447},
        "authority": {"realm": "ncp", "default_deny": true, "principals": [{"principal_id": "operator-1", "certificate_identity": "urn:ncp:operator-1", "entity_id": "body-1", "role": "operator", "planes": ["control"]}]},
        "tls": null,
