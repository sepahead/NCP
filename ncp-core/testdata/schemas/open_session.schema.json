{
  "$defs": {
    "EntityBinding": {
      "description": "Binds a client entity to a stimulus or record port.",
      "properties": {
        "direction": {
          "description": "`\"stimulus\"` | `\"record\"`.",
          "type": "string"
        },
        "entity": {
          "$ref": "#/$defs/EntityRef"
        },
        "port": {
          "type": "string"
        }
      },
      "required": [
        "direction",
        "entity",
        "port"
      ],
      "type": "object"
    },
    "EntityRef": {
      "description": "A hierarchical client-side entity address, e.g. `uav1/sensor/cam0`.",
      "properties": {
        "meta": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "type": "object"
        },
        "path": {
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/EntityRole"
        }
      },
      "required": [
        "path",
        "role"
      ],
      "type": "object"
    },
    "EntityRole": {
      "description": "Hierarchical entity role for addressing sensors/actuators.",
      "oneOf": [
        {
          "enum": [
            "system",
            "actor",
            "sensor",
            "actuator"
          ],
          "type": "string"
        }
      ]
    },
    "GatewayAttribution": {
      "description": "Visible attribution for a deliberately translated legacy payload. Native\npeers omit it; its presence never upgrades the legacy source's security or\nscientific/safety evidence.",
      "properties": {
        "gateway_id": {
          "type": "string"
        },
        "source_wire": {
          "type": "string"
        }
      },
      "required": [
        "gateway_id",
        "source_wire"
      ],
      "type": "object"
    },
    "IdentityClaim": {
      "description": "Payload claim that an authenticated transport adapter binds to its verified\npeer identity. The claim never authenticates itself.",
      "properties": {
        "entity_id": {
          "type": "string"
        },
        "plane": {
          "$ref": "#/$defs/Plane"
        },
        "principal_id": {
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/PrincipalRole"
        }
      },
      "required": [
        "entity_id",
        "plane",
        "principal_id",
        "role"
      ],
      "type": "object"
    },
    "NetworkRef": {
      "description": "What to simulate.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/NetworkRefKind"
        },
        "model_name": {
          "default": null,
          "description": "kind=handle: which registered model to create if the handle has >1.",
          "type": [
            "string",
            "null"
          ]
        },
        "params": {
          "additionalProperties": {
            "format": "double",
            "type": "number"
          },
          "default": {},
          "type": "object"
        },
        "population_sizes": {
          "additionalProperties": {
            "format": "int64",
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
          },
          "default": {},
          "type": "object"
        },
        "ref": {
          "description": "builtin model name, or a `compiled_module_id` (kind=handle). `ref` is a\nRust keyword, so the field is `ref_` and renamed on the wire.",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ],
      "type": "object"
    },
    "NetworkRefKind": {
      "description": "What kind of network reference `NetworkRef.ref` is.",
      "oneOf": [
        {
          "enum": [
            "handle",
            "builtin",
            "model_id",
            "spec"
          ],
          "type": "string"
        }
      ]
    },
    "Observable": {
      "description": "What to record off a population/neuron/synapse.",
      "oneOf": [
        {
          "enum": [
            "spikes",
            "V_m",
            "rate",
            "weight"
          ],
          "type": "string"
        },
        {
          "const": "binary_state",
          "description": "Binary / multi-state neurons: discrete state via spin_detector, not V_m. (#10)",
          "type": "string"
        }
      ]
    },
    "Plane": {
      "description": "Transport plane named by an authenticated principal claim. Security enums are\nclosed: an unknown plane never inherits authority from a known one.",
      "enum": [
        "unknown",
        "control",
        "perception",
        "action",
        "observation"
      ],
      "type": "string"
    },
    "PrincipalRole": {
      "description": "Principal role enrolled by a deployment authority manifest. This is distinct\nfrom the older controller/plant handshake role because observers and operators\nhave security authority without pretending to be a controller or body.",
      "enum": [
        "unknown",
        "commander",
        "body",
        "observer",
        "operator"
      ],
      "type": "string"
    },
    "RecordSpec": {
      "properties": {
        "targets": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RecordTarget"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "RecordTarget": {
      "description": "One recording: client `port` name ← `observable` of `target` population.",
      "properties": {
        "cadence_ms": {
          "default": 1.0,
          "format": "double",
          "type": "number"
        },
        "ids": {
          "default": [],
          "items": {
            "format": "int64",
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
          },
          "type": "array"
        },
        "observable": {
          "$ref": "#/$defs/Observable"
        },
        "port": {
          "type": "string"
        },
        "recordables": {
          "default": [],
          "description": "Generic named multimeter recordables (model-specific: e.g. `g_ex`/`g_in`\nfor conductance models, `w` for aeif, `rate` for rate models). Empty =\njust `observable`. Resolved via NEST multimeter `record_from`. (#10)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "observable",
        "port",
        "target"
      ],
      "type": "object"
    },
    "SimConfig": {
      "description": "Integration / streaming configuration.",
      "properties": {
        "chunk_ms": {
          "default": 10.0,
          "format": "double",
          "type": "number"
        },
        "dt_ms": {
          "default": 0.1,
          "format": "double",
          "type": "number"
        },
        "duration_ms": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "mode": {
          "$ref": "#/$defs/SimMode",
          "default": "stream"
        },
        "seed": {
          "default": null,
          "format": "int64",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SimMode": {
      "description": "Stream vs batch simulation.",
      "oneOf": [
        {
          "enum": [
            "stream",
            "batch"
          ],
          "type": "string"
        }
      ]
    },
    "StimulusKind": {
      "description": "How a stimulus drives a target.",
      "oneOf": [
        {
          "enum": [
            "current_pA",
            "rate_hz",
            "spike_times",
            "weight_set"
          ],
          "type": "string"
        },
        {
          "const": "rate_inject",
          "description": "Continuous-rate injection for rate-based neurons (rate connections /\nstep_rate_generator); rate models cannot receive spikes. (#10)",
          "type": "string"
        }
      ]
    },
    "StimulusSpec": {
      "properties": {
        "targets": {
          "default": [],
          "items": {
            "$ref": "#/$defs/StimulusTarget"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "StimulusTarget": {
      "description": "One stimulus input port.",
      "properties": {
        "ids": {
          "default": [],
          "items": {
            "format": "int64",
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
          },
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/StimulusKind"
        },
        "params": {
          "additionalProperties": {
            "format": "double",
            "type": "number"
          },
          "default": {},
          "description": "Named stimulus parameters beyond the scalar value, e.g. siegert_neuron's\ndiffusion_connection `drift_factor` / `diffusion_factor`. (#10)",
          "type": "object"
        },
        "port": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "port",
        "target"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Request a simulation: declare what to record and what to stimulate.",
  "properties": {
    "bindings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EntityBinding"
      },
      "type": "array"
    },
    "contract_hash": {
      "default": "163acc57d8a62b66",
      "description": "Caller's [`CONTRACT_HASH`], carried in the handshake as an **advisory**\nidentity signal (see [`ContractStatus`]): a mismatch is logged, not rejected —\n`ncp_version` is the hard compatibility gate. Defaults to our own hash so\nevery session advertises it; `None` (serialized `null`) = not advertised.",
      "type": [
        "string",
        "null"
      ]
    },
    "gateway": {
      "anyOf": [
        {
          "$ref": "#/$defs/GatewayAttribution"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Present only when this payload was emitted by a terminating gateway."
    },
    "gateway_permitted": {
      "description": "Explicit opt-in to a labelled 0.8→1.0 gateway. `false` is native-only.",
      "type": "boolean"
    },
    "identity": {
      "$ref": "#/$defs/IdentityClaim",
      "description": "Authenticated caller claim; the transport adapter binds it to the peer\ncertificate before opening any session state."
    },
    "kind": {
      "const": "open_session",
      "type": "string"
    },
    "ncp_version": {
      "pattern": "^1(?:\\.(?:0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]{1}|1844674407370955161[0-4]|18446744073709551615))?(?![\\s\\S])",
      "type": "string"
    },
    "network": {
      "$ref": "#/$defs/NetworkRef"
    },
    "record": {
      "$ref": "#/$defs/RecordSpec",
      "default": {
        "targets": []
      }
    },
    "security_profile": {
      "type": "string"
    },
    "security_state_digest": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "sim": {
      "$ref": "#/$defs/SimConfig",
      "default": {
        "chunk_ms": 10.0,
        "dt_ms": 0.1,
        "duration_ms": null,
        "mode": "stream",
        "seed": null
      }
    },
    "stimulus": {
      "$ref": "#/$defs/StimulusSpec",
      "default": {
        "targets": []
      }
    }
  },
  "required": [
    "gateway_permitted",
    "identity",
    "kind",
    "ncp_version",
    "network",
    "security_profile",
    "security_state_digest",
    "session_id"
  ],
  "title": "OpenSession",
  "type": "object"
}
