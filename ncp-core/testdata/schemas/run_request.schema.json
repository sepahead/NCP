{
  "$defs": {
    "ChannelValue": {
      "description": "A channel sample: a flat list of floats plus an optional unit string. Width\ncarries the semantics (1=scalar, 3=vec3, 4=quat, N=array).",
      "properties": {
        "data": {
          "default": [],
          "items": {
            "format": "double",
            "type": "number"
          },
          "type": "array"
        },
        "unit": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "StimulusFrame": {
      "description": "The values to inject this step (keyed by stimulus port). `t` is\nproducer-local monotonic seconds and is never compared across peers.",
      "properties": {
        "kind": {
          "const": "stimulus_frame",
          "type": "string"
        },
        "ncp_version": {
          "const": "0.7",
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "t": {
          "default": 0.0,
          "format": "double",
          "type": "number"
        },
        "values": {
          "additionalProperties": {
            "$ref": "#/$defs/ChannelValue"
          },
          "default": {},
          "type": "object"
        }
      },
      "required": [
        "kind",
        "ncp_version",
        "session_id"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Batch: advance `duration_ms` holding a stimulus; returns an `ObservationFrame`.",
  "properties": {
    "duration_ms": {
      "format": "double",
      "type": "number"
    },
    "kind": {
      "const": "run_request",
      "type": "string"
    },
    "ncp_version": {
      "const": "0.7",
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "stimulus": {
      "anyOf": [
        {
          "$ref": "#/$defs/StimulusFrame"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "duration_ms",
    "kind",
    "ncp_version",
    "session_id"
  ],
  "title": "RunRequest",
  "type": "object"
}
