{
  "$defs": {
    "ChannelKind": {
      "description": "Channel arity (carries the vec semantics so the envelope stays generic).",
      "oneOf": [
        {
          "enum": [
            "scalar",
            "vec3",
            "quat",
            "array"
          ],
          "type": "string"
        }
      ]
    },
    "ChannelRequirement": {
      "description": "Whether a negotiated channel is mandatory. Wire 1.0 deliberately makes\nabsence/`\"unknown\"` non-authorizing; wire 0.8's missing `optional` boolean\noptimistically defaulted to `true` and is accepted only by the labelled gateway.",
      "oneOf": [
        {
          "enum": [
            "unknown",
            "required",
            "optional"
          ],
          "type": "string"
        }
      ]
    },
    "ChannelSpec": {
      "description": "Declares a named channel a controller produces or consumes.",
      "properties": {
        "description": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/$defs/ChannelKind"
        },
        "name": {
          "type": "string"
        },
        "requirement": {
          "$ref": "#/$defs/ChannelRequirement"
        },
        "size": {
          "default": null,
          "format": "int64",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": [
            "integer",
            "null"
          ]
        },
        "unit": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "name",
        "requirement"
      ],
      "type": "object"
    },
    "GatewayAttribution": {
      "description": "Visible attribution for a deliberately translated legacy payload. Native\npeers omit it; its presence never upgrades the legacy source's security or\nscientific/safety evidence.",
      "properties": {
        "gateway_id": {
          "type": "string"
        },
        "source_wire": {
          "type": "string"
        }
      },
      "required": [
        "gateway_id",
        "source_wire"
      ],
      "type": "object"
    },
    "IdentityClaim": {
      "description": "Payload claim that an authenticated transport adapter binds to its verified\npeer identity. The claim never authenticates itself.",
      "properties": {
        "entity_id": {
          "type": "string"
        },
        "plane": {
          "$ref": "#/$defs/Plane"
        },
        "principal_id": {
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/PrincipalRole"
        }
      },
      "required": [
        "entity_id",
        "plane",
        "principal_id",
        "role"
      ],
      "type": "object"
    },
    "Plane": {
      "description": "Transport plane named by an authenticated principal claim. Security enums are\nclosed: an unknown plane never inherits authority from a known one.",
      "enum": [
        "unknown",
        "control",
        "perception",
        "action",
        "observation"
      ],
      "type": "string"
    },
    "PrincipalRole": {
      "description": "Principal role enrolled by a deployment authority manifest. This is distinct\nfrom the older controller/plant handshake role because observers and operators\nhave security authority without pretending to be a controller or body.",
      "enum": [
        "unknown",
        "commander",
        "body",
        "observer",
        "operator"
      ],
      "type": "string"
    },
    "Role": {
      "description": "Who a peer is in the closed-loop handshake.",
      "oneOf": [
        {
          "enum": [
            "controller",
            "plant",
            "observer",
            "operator"
          ],
          "type": "string"
        }
      ]
    },
    "SafetyLimits": {
      "description": "Bounds the action plane. `max_speed_mps`, `geofence_radius_m` and\n`command_timeout_ms` are enforced by the action-plane safety governor;\n`max_tilt_rad` is advisory metadata and is **not** enforced in this layer\n(no command-path clamp consumes it yet).",
      "properties": {
        "command_timeout_ms": {
          "format": "double",
          "type": "number"
        },
        "geofence_radius_m": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "max_speed_mps": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "max_tilt_rad": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "command_timeout_ms"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Handshake: who the controller is and what it speaks.",
  "properties": {
    "codec_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "command_channels": {
      "items": {
        "$ref": "#/$defs/ChannelSpec"
      },
      "type": "array"
    },
    "control_rate_hz": {
      "format": "double",
      "type": "number"
    },
    "controller_id": {
      "type": "string"
    },
    "gateway": {
      "anyOf": [
        {
          "$ref": "#/$defs/GatewayAttribution"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gateway_permitted": {
      "description": "`false` means native 1.0 only. A gateway is never inferred from absence.",
      "type": "boolean"
    },
    "identity": {
      "$ref": "#/$defs/IdentityClaim"
    },
    "kind": {
      "const": "capabilities",
      "type": "string"
    },
    "ncp_version": {
      "pattern": "^1(?:\\.(?:0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]{1}|1844674407370955161[0-4]|18446744073709551615))?(?![\\s\\S])",
      "type": "string"
    },
    "plant_profile_digest": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "role": {
      "$ref": "#/$defs/Role"
    },
    "safety": {
      "$ref": "#/$defs/SafetyLimits"
    },
    "security_profile": {
      "type": "string"
    },
    "security_state_digest": {
      "type": "string"
    },
    "sensor_channels": {
      "items": {
        "$ref": "#/$defs/ChannelSpec"
      },
      "type": "array"
    },
    "stable_capabilities": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "command_channels",
    "control_rate_hz",
    "controller_id",
    "gateway_permitted",
    "identity",
    "kind",
    "ncp_version",
    "role",
    "safety",
    "security_profile",
    "security_state_digest",
    "sensor_channels",
    "stable_capabilities"
  ],
  "title": "Capabilities",
  "type": "object"
}
