{
  "$defs": {
    "AuthorityLease": {
      "description": "One bounded authority term for a single session incarnation. UTC timestamps\nare receipt/audit bounds; receivers derive a local monotonic expiry deadline.",
      "properties": {
        "expires_at_utc_ms": {
          "format": "int64",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer"
        },
        "holder_entity_id": {
          "type": "string"
        },
        "holder_principal_id": {
          "type": "string"
        },
        "issued_at_utc_ms": {
          "format": "int64",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer"
        },
        "issuer_principal_id": {
          "type": "string"
        },
        "lease_id": {
          "type": "string"
        },
        "session_epoch": {
          "type": "string"
        },
        "term": {
          "format": "uint64",
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "expires_at_utc_ms",
        "holder_entity_id",
        "holder_principal_id",
        "issued_at_utc_ms",
        "issuer_principal_id",
        "lease_id",
        "session_epoch",
        "term"
      ],
      "type": "object"
    },
    "OperationContext": {
      "description": "Caller-provided exactly-once context for a state-mutating lifecycle RPC.",
      "properties": {
        "deadline_utc_ms": {
          "format": "int64",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer"
        },
        "expected_state_version": {
          "format": "uint64",
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "operation_id": {
          "type": "string"
        },
        "request_digest": {
          "type": "string"
        },
        "retry": {
          "type": "boolean"
        },
        "session_epoch": {
          "type": "string"
        }
      },
      "required": [
        "deadline_utc_ms",
        "expected_state_version",
        "operation_id",
        "request_digest",
        "retry",
        "session_epoch"
      ],
      "type": "object"
    },
    "SessionRef": {
      "description": "One live session incarnation (`proto/ncp.proto` `SessionRef`). The routing\n`session_id` (carried alongside on every session-scoped frame) remains the logical\nname; this server-issued `generation` distinguishes one opening of that id from a\nlater reuse, so a stale-session frame is rejectable. The pair\n`(session_id, generation)` identifies the live instance; `\"\"` = unset.",
      "properties": {
        "generation": {
          "type": "string"
        }
      },
      "required": [
        "generation"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "authority": {
      "$ref": "#/$defs/AuthorityLease"
    },
    "kind": {
      "const": "close_session",
      "type": "string"
    },
    "ncp_version": {
      "pattern": "^1(?:\\.(?:0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]{1}|1844674407370955161[0-4]|18446744073709551615))?(?![\\s\\S])",
      "type": "string"
    },
    "operation": {
      "$ref": "#/$defs/OperationContext"
    },
    "session": {
      "$ref": "#/$defs/SessionRef",
      "description": "(0.8) REQUIRED: a delayed close for an old incarnation must not close a reopen."
    },
    "session_id": {
      "type": "string"
    }
  },
  "required": [
    "authority",
    "kind",
    "ncp_version",
    "operation",
    "session",
    "session_id"
  ],
  "title": "CloseSession",
  "type": "object"
}
