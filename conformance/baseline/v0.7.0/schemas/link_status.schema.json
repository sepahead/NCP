{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Link-health telemetry from the seq-gap / CUSUM monitor (published on the\ncontrol plane). `burst=true` flags sustained loss — a possible jam — at which\npoint the only sound response is to fail safe, not add redundancy. `t` is\nproducer-local monotonic seconds and is never compared across peers.",
  "properties": {
    "burst": {
      "type": "boolean"
    },
    "kind": {
      "const": "link_status",
      "type": "string"
    },
    "last_seq": {
      "format": "int64",
      "maximum": 9007199254740991,
      "minimum": -9007199254740991,
      "type": "integer"
    },
    "loss_rate": {
      "format": "double",
      "type": "number"
    },
    "lost": {
      "format": "int64",
      "maximum": 9007199254740991,
      "minimum": -9007199254740991,
      "type": "integer"
    },
    "ncp_version": {
      "const": "0.7",
      "type": "string"
    },
    "received": {
      "format": "int64",
      "maximum": 9007199254740991,
      "minimum": -9007199254740991,
      "type": "integer"
    },
    "session_id": {
      "type": "string"
    },
    "t": {
      "format": "double",
      "type": "number"
    }
  },
  "required": [
    "burst",
    "kind",
    "last_seq",
    "loss_rate",
    "lost",
    "ncp_version",
    "received",
    "session_id",
    "t"
  ],
  "title": "LinkStatus",
  "type": "object"
}
