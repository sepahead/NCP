{
  "$defs": {
    "Mode": {
      "description": "Controller mode (the safety-critical action authority lives here). Unknown\nadditive strings are preserved, but every safety decision treats them exactly\nlike a non-Active mode and emits HOLD.",
      "minLength": 1,
      "type": "string",
      "x-ncp-known-values": [
        "init",
        "active",
        "hold",
        "estop"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Controller → plant / telemetry: loop health and mode. `t` is producer-local\nmonotonic seconds and is never compared across peers.",
  "properties": {
    "kind": {
      "const": "control_status",
      "type": "string"
    },
    "loop_latency_ms": {
      "format": "double",
      "type": "number"
    },
    "mode": {
      "$ref": "#/$defs/Mode"
    },
    "ncp_version": {
      "const": "0.7",
      "type": "string"
    },
    "note": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "safety_ok": {
      "type": "boolean"
    },
    "seq": {
      "format": "int64",
      "maximum": 9007199254740991,
      "minimum": -9007199254740991,
      "type": "integer"
    },
    "sim_time_ms": {
      "default": 0.0,
      "format": "double",
      "type": "number"
    },
    "t": {
      "format": "double",
      "type": "number"
    }
  },
  "required": [
    "kind",
    "loop_latency_ms",
    "mode",
    "ncp_version",
    "safety_ok",
    "seq",
    "t"
  ],
  "title": "ControlStatus",
  "type": "object"
}
