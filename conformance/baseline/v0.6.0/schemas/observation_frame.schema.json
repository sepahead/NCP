{
  "$defs": {
    "Observable": {
      "description": "What to record off a population/neuron/synapse.",
      "oneOf": [
        {
          "enum": [
            "spikes",
            "V_m",
            "rate",
            "weight"
          ],
          "type": "string"
        },
        {
          "const": "binary_state",
          "description": "Binary / multi-state neurons: discrete state via spin_detector, not V_m. (#10)",
          "type": "string"
        }
      ]
    },
    "Observation": {
      "description": "Recorded data for one record port. `times`+`values` are parallel for analog;\n`times`+`senders` are parallel for spikes.",
      "properties": {
        "observable": {
          "$ref": "#/$defs/Observable",
          "default": "V_m"
        },
        "port": {
          "default": "",
          "type": "string"
        },
        "recordable": {
          "default": null,
          "description": "Which named recordable this series carries (e.g. `g_ex`, `w`) when a port\nrecords more than the primary `observable`; `None` = the `observable`. (#10)",
          "type": [
            "string",
            "null"
          ]
        },
        "senders": {
          "default": [],
          "items": {
            "format": "int64",
            "type": "integer"
          },
          "type": "array"
        },
        "target": {
          "default": "",
          "type": "string"
        },
        "times": {
          "default": [],
          "items": {
            "format": "double",
            "type": "number"
          },
          "type": "array"
        },
        "unit": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "values": {
          "default": [],
          "items": {
            "format": "double",
            "type": "number"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The returned neural data, keyed by record port.",
  "properties": {
    "calibrated_posterior": {
      "default": false,
      "type": "boolean"
    },
    "is_simulation_output": {
      "default": true,
      "type": "boolean"
    },
    "kind": {
      "const": "observation_frame",
      "default": "",
      "type": "string"
    },
    "ncp_version": {
      "const": "0.6",
      "default": "",
      "type": "string"
    },
    "records": {
      "additionalProperties": {
        "$ref": "#/$defs/Observation"
      },
      "default": {},
      "type": "object"
    },
    "seq": {
      "default": 0,
      "description": "Wire 0.6 (normative): a frame **published on the observation plane** MUST\necho the driving `SensorFrame.seq` (`>= 1`), so a split-plane observer can\nalign `(V,L,D,A)` on `seq` (not arrival time) — an unstamped plane frame\nforces observers into a degraded recency-only join. `0` is reserved for\nthe pure pull/sim-service RPC reply path (no controller seq exists there).",
      "format": "int64",
      "type": "integer"
    },
    "session_id": {
      "default": "",
      "type": "string"
    },
    "sim_time_ms": {
      "default": 0.0,
      "format": "double",
      "type": "number"
    },
    "t": {
      "default": 0.0,
      "format": "double",
      "type": "number"
    }
  },
  "required": [
    "ncp_version",
    "seq",
    "session_id"
  ],
  "title": "ObservationFrame",
  "type": "object"
}
