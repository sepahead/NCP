{
  "name": "@sepahead/ncp",
  "version": "0.8.0",
  "description": "Canonical NCP (Neuro-Cybernetic Protocol) TypeScript types + transport-agnostic client. Wire-identical to the normative proto/ncp.proto contract (proto-native) and the Rust and Python peers.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "repository": { "type": "git", "url": "git+https://github.com/sepahead/NCP.git" },
  "homepage": "https://github.com/sepahead/NCP#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE-MIT", "LICENSE-APACHE"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "sync": "node scripts/sync-bindings.mjs",
    "build": "tsc -p tsconfig.json",
    "check:behavior": "node scripts/check-behavior.mjs",
    "check:ws": "node scripts/check-ws.mjs",
    "check:package": "node scripts/check-package.mjs",
    "regen": "cargo test -p ncp-core --features ts && node scripts/sync-bindings.mjs && tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": { "typescript": "5.9.2" }
}
