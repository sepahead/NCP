{
  "name": "@sepahead/ncp",
  "version": "1.0.0-rc.1",
  "description": "NCP (Neuro-Cybernetic Protocol) canonical-JSON TypeScript types and transport-agnostic client, conforming to the repository's normative registries, field-shape IDL, schemas, specification, and mandatory corpus.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "repository": { "type": "git", "url": "git+https://github.com/sepahead/NCP.git" },
  "homepage": "https://github.com/sepahead/NCP#readme",
  "exports": {
    ".": {
      "types": "./ncp-ts/dist/index.d.ts",
      "import": "./ncp-ts/dist/index.js"
    }
  },
  "files": [
    "ncp-ts/dist",
    "ncp-ts/src",
    "ncp-ts/README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "sync": "node ncp-ts/scripts/sync-bindings.mjs",
    "build": "tsc -p ncp-ts/tsconfig.json",
    "check:behavior": "node ncp-ts/scripts/check-behavior.mjs",
    "check:ws": "node ncp-ts/scripts/check-ws.mjs",
    "check:package": "node ncp-ts/scripts/check-package.mjs && node ncp-ts/scripts/build-release.mjs --self-test",
    "build:npm-release": "node ncp-ts/scripts/build-release.mjs",
    "regen": "cargo test -p ncp-core --features ts && node ncp-ts/scripts/sync-bindings.mjs && tsc -p ncp-ts/tsconfig.json",
    "clean": "rm -rf ncp-ts/dist"
  },
  "devDependencies": { "typescript": "5.9.2" }
}
